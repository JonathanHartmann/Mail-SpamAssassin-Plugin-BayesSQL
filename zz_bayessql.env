# =====================================================================
# Konfiguration für ZZ_BayesSQL SpamAssassin Plugin
# =====================================================================

# ---------------------------------------------------------------------
# PFLICHTFELDER (Das Plugin wird deaktiviert, wenn diese fehlen)
# ---------------------------------------------------------------------

# Die DSN (Data Source Name) für die Datenbankverbindung.
# Format: DBI:Treiber:Datenbankname:Host:Port
EC_BAYES_SQL_DSN = "DBI:mysql:spamassassin_bayes:localhost:3306"

# Der Datenbank-Benutzername
EC_BAYES_SQL_USER = "bayes_dbuser"

# Das Datenbank-Passwort. 
# Hinweis: Passwörter dürfen jetzt Sonderzeichen wie '#' enthalten, 
# da das Plugin nur noch komplette Kommentarzeilen ignoriert.
EC_BAYES_SQL_PASS = "Secretpassword"

# Ab welchem Score soll der "SA-EC-High-SPAM" Header gesetzt werden?
# Erlaubt sind ganze Zahlen oder Dezimalzahlen (mit Punkt).
EC_HIGHSPAM_THRESHOLD = 15.0

